# Application
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=info

# Ollama (for answer generation)
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=phi3:mini

# Embeddings (local)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Reranker (local cross-encoder)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval
CHUNK_SIZE=512
CHUNK_OVERLAP=64
BM25_TOP_K=20
VECTOR_TOP_K=20
RERANK_TOP_K=5

# Vector store
CHROMA_PERSIST_DIR=/app/chroma_data

# Corpus
CORPUS_DIR=/app/corpus
