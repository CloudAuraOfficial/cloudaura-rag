# ── Shared Configuration ──────────────────────────
LOG_LEVEL=info

# Ollama (shared across all sub-projects)
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=phi3:mini

# Embeddings (P1-P4: sentence-transformers, local)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Reranker (P1-P4: cross-encoder, local)
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval (P1-P4)
CHUNK_SIZE=512
CHUNK_OVERLAP=64
BM25_TOP_K=20
VECTOR_TOP_K=20
RERANK_TOP_K=5

# ── P5 Advanced (LightRAG) ──────────────────────
LIGHTRAG_EMBEDDING_MODEL=nomic-embed-text:latest
DEMO_MODE=true
